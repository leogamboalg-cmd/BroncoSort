{
  "name": "ratemyprofessors-client",
  "version": "2.1.5",
  "type": "module",
  "description": "Typed, retrying, rate-limited unofficial client for RateMyProfessors.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "homepage": "https://github.com/amaanjaved1/rate-my-professors-client-ts#readme",
  "bugs": {
    "url": "https://github.com/amaanjaved1/rate-my-professors-client-ts/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./extras": {
      "types": "./dist/extras/index.d.ts",
      "import": "./dist/extras/index.js",
      "default": "./dist/extras/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ratemyprofessors",
    "api-client",
    "ratings"
  ],
  "author": "Amaan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amaanjaved1/rate-my-professors-client-ts.git"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/sentiment": "^5.0.4",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "sentiment": "^5.0.2"
  }
}
