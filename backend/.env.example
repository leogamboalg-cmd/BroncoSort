# Local backend environment variables
PORT=3000

# Upstash Redis (ratings cache, rankings, summaries, and collected data)
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace_with_your_upstash_token

# U.S. Department of Education College Scorecard
COLLEGE_SCORECARD_API_KEY=replace_with_your_college_scorecard_key

# Google Gemini professor-review summaries
GEMINI_API_KEY=replace_with_your_gemini_key

# Stripe Checkout
STRIPE_SECRET_KEY=sk_test_replace_with_your_secret_key
STRIPE_PRICE_ID=price_replace_with_your_price_id
FRONTEND_URL=http://localhost:5500
